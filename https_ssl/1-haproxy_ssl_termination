global
    log /dev/log local0
    maxconn 2048
    tune.ssl.default-dh-param 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend http_front
    bind *:80
    bind *:443 ssl crt /etc/ssl/www.espoir.tech.pem
    default_backend http_back

backend http_back
    balance roundrobin
    server web-01 44.201.255.156:80 check
    server web-02 44.202.105.198:80 check
